# Copy this file to secrets.yaml and fill in your values.
# secrets.yaml is git-ignored and must NOT be committed.

# WiFi
wifi_ssid: "YourWiFiNetwork"
wifi_password: "YourWiFiPassword"

# MQTT broker — required for solis-lilygo-mqtt.yaml
# Leave blank / remove if using the native API variant (solis-lilygo.yaml)
mqtt_broker: 192.168.10.x
mqtt_username: mqtt_user
mqtt_password: mqtt_password
